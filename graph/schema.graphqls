type User {
  id: ID!
  email: String!
}

type AuthPayload {
  accessToken: String!
  refreshToken: String!
}

type Query {
  me: User
}

type Mutation {
  login(email: String!, password: String!): AuthPayload!
  refresh(refreshToken: String!): AuthPayload!
  logout(refreshToken: String!): Boolean!
}